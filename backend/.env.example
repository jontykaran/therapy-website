# Database (PostgreSQL)
DATABASE_URL=jdbc:postgresql://localhost:5432/therapydb
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password
DATABASE_DRIVER=org.postgresql.Driver

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Notifications
NOTIFICATION_EMAIL=hello@therapybyrashi.com

# CORS (comma-separated frontend URLs)
CORS_ORIGINS=https://your-domain.com,http://localhost:5173

# Server
PORT=8080

# H2 Console (disable in production)
H2_CONSOLE=false

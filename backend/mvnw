#!/bin/sh
# Maven Wrapper script
# Adapted from https://github.com/apache/maven-wrapper

set -e

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-$(cd "$(dirname "$0")" && pwd)}"
MAVEN_WRAPPER_JAR="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES="$MAVEN_PROJECTBASEDIR/.mvn/wrapper/maven-wrapper.properties"

# Determine Maven home
if [ -z "$MAVEN_HOME" ]; then
    MAVEN_HOME="$HOME/.m2/wrapper/dists/apache-maven-3.9.9"
fi

MAVEN_CMD="$MAVEN_HOME/bin/mvn"

# Download Maven if needed
if [ ! -f "$MAVEN_CMD" ]; then
    echo "Downloading Apache Maven 3.9.9..."
    mkdir -p "$MAVEN_HOME"
    DIST_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/3.9.9/apache-maven-3.9.9-bin.tar.gz"
    curl -fsSL "$DIST_URL" | tar -xz -C "$MAVEN_HOME" --strip-components=1
    echo "Maven downloaded to $MAVEN_HOME"
fi

exec "$MAVEN_CMD" "$@" -f "$MAVEN_PROJECTBASEDIR/pom.xml"
